{
  "Callout Info": {
    "prefix": "cinfo",
    "body": ["> [!INFO] ${1:Título}", "> ${0:Contenido}"],
    "description": "Callout informativo azul"
  },
  "Callout Warning": {
    "prefix": "cwarn",
    "body": ["> [!WARNING] ${1:Cuidado}", "> ${0:Contenido}"],
    "description": "Callout de advertencia amarillo"
  },
  "Callout Danger": {
    "prefix": "cdang",
    "body": ["> [!DANGER] ${1:Peligro}", "> ${0:Contenido}"],
    "description": "Callout de peligro rojo"
  },
  "Callout Todo": {
    "prefix": "ctodo",
    "body": ["> [!TODO] ${1:Por hacer}", "> ${0:Contenido}"],
    "description": "Callout de lista de tareas"
  },
  "Bold Text": {
    "prefix": "bb",
    "body": "**${1:texto}**$0",
    "description": "Formato negrita"
  },
  "Callout Dinámico": {
    "prefix": "call",
    "body": [
      "> [!${1|INFO,TODO,WARNING,DANGER,ERROR,HINT,NOTE|}] ${2:Título}",
      "> ${0:Contenido}"
    ],
    "description": "Insertar Callout con selector de tipo"
  },
  "CTF Target Header": {
    "prefix": "target",
    "body": [
      "## Información del Objetivo",
      "",
      "- **IP:** `${1:10.10.11.X}`",
      "- **OS:** ${2|Linux,Windows|}",
      "- **Dificultad:** ${3|Easy,Medium,Hard,Insane|}",
      "- **Nombre:** **${4:MachineName}**",
      "",
      "---",
      "$0"
    ],
    "description": "Cabecera rápida para iniciar una máquina"
  },
  "HTB Flag": {
    "prefix": "flag",
    "body": [
      "> [!SUCCESS] Flag Capturada (${1|User,Root|})",
      "> `HTB{${2:hash_aqui}}`$0"
    ],
    "description": "Callout verde para resaltar la flag"
  },
  "Credentials Box": {
    "prefix": "creds",
    "body": [
      "| Usuario | Contraseña | Servicio | Hash |",
      "| :--- | :--- | :--- | :--- |",
      "| `${1:admin}` | `${2:password}` | ${3:SSH/RDP} | ${4:N/A} |",
      "$0"
    ],
    "description": "Tabla rápida para guardar credenciales encontradas"
  },
  "PtH Evidence Box": {
    "prefix": "creds-pth",
    "body": [
      "| Host | Usuario | Hash NTLM | Técnica | Estado |",
      "| :--- | :--- | :--- | :--- | :--- |",
      "| ${1:MS01 (10.129.201.126)} | ${2:Administrator (RID-500)} | `${3:30B3783CE2ABF1AF70F77D0660CF3453}` | ${4:Pass the Hash (PtH)} | **${5:Pwn3d! (Acceso Administrativo)}** |",
      "",
      "$0"
    ],
    "description": "Tabla detallada para hallazgos de Pass the Hash"
  },
  "Bash Block": {
    "prefix": "shell",
    "body": ["```bash", "${1:comando}", "```", "$0"],
    "description": "Bloque de código Bash"
  },
  "Python Block": {
    "prefix": "py",
    "body": ["```python", "${0}", "```"],
    "description": "Bloque de código Python"
  },
  "Nmap Output": {
    "prefix": "nmap",
    "body": [
      "> [!EXAMPLE]- Resultado Nmap",
      "> ```bash",
      "> ${0:Pegar output aquí}",
      "> ```"
    ],
    "description": "Callout colapsable (-) para no llenar la nota con logs largos"
  },
  "Frontmatter Note": {
    "prefix": "fm",
    "body": [
      "---",
      "id: ${1:nombre_nota}",
      "tags:",
      "  - ${2|cpent,linux,windows,web,networking|}",
      "date: ${CURRENT_YEAR}-${CURRENT_MONTH}-${CURRENT_DATE}",
      "---",
      "",
      "# $1",
      "$0"
    ],
    "description": "Insertar metadatos YAML al inicio"
  },
  "Collapsible Section": {
    "prefix": "fold",
    "body": [
      "<details>",
      "<summary>${1:Título del spoiler}</summary>",
      "",
      "${0:Contenido oculto}",
      "",
      "</details>"
    ],
    "description": "Crear una sección desplegable HTML nativa"
  },
  "Bold (Negrita)": {
    "prefix": "b",
    "body": "**$1**$0",
    "description": "Texto en negrita con cursor al medio"
  },
  "Italic (Cursiva)": {
    "prefix": "i",
    "body": "*$1*$0",
    "description": "Texto en cursiva con cursor al medio"
  },
  "Strike (Tachado)": {
    "prefix": "s",
    "body": "~~$1~~$0",
    "description": "Texto tachado"
  },
  "Highlight (Resaltado Obsidian)": {
    "prefix": "h",
    "body": "==$1==$0",
    "description": "Texto resaltado (estilo marcador)"
  },
  "Inline Code (Código en línea)": {
    "prefix": "c",
    "body": "`$1`$0",
    "description": "Código en línea (backticks)"
  },
  "Link (Enlace)": {
    "prefix": "link",
    "body": "[${1:texto}](${2:url})$0",
    "description": "Insertar enlace Markdown"
  },
  "Image (Imagen)": {
    "prefix": "img",
    "body": "![${1:alt}](${2:ruta})$0",
    "description": "Insertar imagen Markdown"
  },
  "Task (Tarea)": {
    "prefix": "todo",
    "body": "- [ ] $1",
    "description": "Checkbox de tarea vacía"
  },
  "Task Done (Tarea lista)": {
    "prefix": "done",
    "body": "- [x] $1",
    "description": "Checkbox de tarea completada"
  },
  "Horizontal Rule (Separador)": {
    "prefix": "sep",
    "body": ["", "---", ""],
    "description": "Línea separadora horizontal"
  }
}
